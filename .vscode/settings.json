{
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    ".husky": true,
    ".turbo": true,
    ".gitignore": true,
    ".npmrc": true,
    ".prettierignore": true,
    ".prettierrc": true,
    "package-lock.json": true,
    "package.json": true,
    "README.md": true,
    "turbo.json": true,
    "node_modules": true,
    ".vscode": true,
    "apps/web/.next": true,
    "apps/web/.turbo": true,
    "apps/web/node_modules": true,
    "apps/web/.gitignore": true,
    "apps/web/components.json": true,
    "apps/web/next-env.d.ts": true,
    "apps/web/next.config.js": true,
    "apps/web/postcss.config.mjs": true,
    "apps/web/README.md": true,
    "apps/web/src/app/fonts": true,
    "apps/web/src/types": true,
    "apps/web/src/lib": true,
    "apps/web/src/hooks": true,
    "apps/web/public": true,
    "apps/web/src/providers": true,
    "apps/web/src/components/ui": true,
    "apps/web/src/components/typography": true,
    "apps/web/src/app/(projects)/layout.tsx": true,
    "packages": true
  },
  "hide-files.files": [
    ".husky",
    ".turbo",
    ".gitignore",
    ".npmrc",
    ".prettierignore",
    ".prettierrc",
    "package-lock.json",
    "package.json",
    "README.md",
    "turbo.json",
    "node_modules",
    ".vscode",
    "apps/web/.next",
    "apps/web/.turbo",
    "apps/web/node_modules",
    "apps/web/.gitignore",
    "apps/web/components.json",
    "apps/web/next-env.d.ts",
    "apps/web/next.config.js",
    "apps/web/postcss.config.mjs",
    "apps/web/README.md",
    "apps/web/src/app/fonts",
    "apps/web/src/types",
    "apps/web/src/lib",
    "apps/web/src/hooks",
    "apps/web/public",
    "apps/web/src/providers",
    "apps/web/src/components/ui",
    "apps/web/src/components/typography",
    "apps/web/src/app/(projects)/layout.tsx",
    "packages"
  ]
}
